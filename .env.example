# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Local PostgreSQL Server Database Configuration
# Option 1: Direct Connection String (e.g. postgresql://postgres:password@localhost:5432/my_database)
DATABASE_URL=

# Option 2: Individual Connection Parameters
SQL_HOST=localhost
SQL_PORT=5432
SQL_USER=postgres
SQL_PASSWORD=
SQL_DB_NAME=my_database

# Schema Isolation for Co-existing Applications on the same PostgreSQL Database
# Change DB_SCHEMA (e.g., shift_app) so tables won't interfere with other apps on the same DB
DB_SCHEMA=shift_app

# SSL Mode for Local PostgreSQL Server (Set to false for standard local PostgreSQL servers)
DB_SSL=false
