{
  "entities": {
    "ScheduleAppData": {
      "title": "ScheduleAppData",
      "description": "Core schedule, department, shift types and employee roster stored in a single document for easy real-time syncing",
      "type": "object",
      "properties": {
        "departments": {
          "type": "array",
          "description": "List of system departments"
        },
        "employees": {
          "type": "array",
          "description": "List of employees"
        },
        "shiftTypes": {
          "type": "array",
          "description": "Available shifts configurations"
        },
        "schedule": {
          "type": "object",
          "description": "Schedules dictionary keyed by date string"
        },
        "settings": {
          "type": "object",
          "description": "General system configuration including theme, password, company name, and location settings"
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp of the last update"
        }
      },
      "required": ["departments", "employees", "shiftTypes", "schedule", "settings", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "admin"] },
        "permissions": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "password", "role", "createdAt"]
    },
    "RegistrationRequest": {
      "title": "RegistrationRequest",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "username": { "type": "string" },
        "phone": { "type": "string" },
        "password": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "object" }
      },
      "required": ["name", "type", "phone", "password", "status", "createdAt"]
    },
    "EmployeeRequest": {
      "title": "EmployeeRequest",
      "type": "object",
      "properties": {
        "empId": { "type": "string" },
        "empName": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "note": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "number" },
        "swapWithEmpId": { "type": "string" },
        "swapWithEmpName": { "type": "string" },
        "targetShift": { "type": "string" },
        "reviewedBy": { "type": "string" },
        "reviewedAt": { "type": "string" }
      },
      "required": ["empId", "empName", "type", "date", "status", "createdAt"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "type": "object",
      "properties": {
        "empId": { "type": "string" },
        "empName": { "type": "string" },
        "dept": { "type": "string" },
        "date": { "type": "string" },
        "checkIn": { "type": "string" },
        "checkInTs": { "type": "number" },
        "checkOut": { "type": "string" },
        "checkOutTs": { "type": "number" },
        "status": { "type": "string" },
        "checkInLat": { "type": "number" },
        "checkInLng": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["empId", "empName", "dept", "date", "checkIn", "checkInTs", "status", "createdAt"]
    }
  },
  "firestore": {
    "/scheduleApp/{docId}": {
      "schema": "ScheduleAppData",
      "description": "App content document sync"
    },
    "/admins/{docId}": {
      "schema": "Admin",
      "description": "List of administrators"
    },
    "/registrationRequests/{docId}": {
      "schema": "RegistrationRequest",
      "description": "Employee or manager sign-up request queue"
    },
    "/requests/{docId}": {
      "schema": "EmployeeRequest",
      "description": "Employee leaves, swaps, or shift changes"
    },
    "/attendance/{docId}": {
      "schema": "AttendanceRecord",
      "description": "Attendance punch clock logs"
    }
  }
}
